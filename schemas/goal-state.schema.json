{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.goal-lifecycle/schemas/goal-state.schema.json",
  "title": "Goal State",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "queue", "entries"],
  "properties": {
    "version": {
      "const": 2
    },
    "generated_at": {
      "type": "string"
    },
    "queue": {
      "$ref": "#/$defs/queue"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "project",
        "root_id",
        "goal_key",
        "goal_root",
        "contract_path",
        "plan_path",
        "evidence_path",
        "owner",
        "updated",
        "completed",
        "review",
        "evidence",
        "scheduling",
        "next_action",
        "blocked_reason",
        "source_hash",
        "last_seen",
        "issues"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "draft",
            "review_pending",
            "ready",
            "in_progress",
            "blocked",
            "completed",
            "cancelled",
            "missing",
            "parse_error"
          ]
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "root_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_key": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "goal_root": {
          "type": "string"
        },
        "contract_path": {
          "type": "string"
        },
        "plan_path": {
          "type": ["string", "null"]
        },
        "evidence_path": {
          "type": ["string", "null"]
        },
        "owner": {
          "type": ["string", "null"]
        },
        "updated": {
          "type": ["string", "null"]
        },
        "completed": {
          "type": ["string", "null"]
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "verdict"],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "verdict": {
              "enum": ["pending", "PASS", "FAIL", "NEEDS_EVIDENCE", null]
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "enum": ["pending", "partial", "complete", null]
            }
          }
        },
        "health": {
          "$ref": "#/$defs/health"
        },
        "scheduling": {
          "$ref": "#/$defs/scheduling"
        },
        "next_action": {
          "type": ["string", "null"]
        },
        "blocked_reason": {
          "type": ["string", "null"]
        },
        "source_hash": {
          "type": "string"
        },
        "last_seen": {
          "type": "string"
        },
        "issues": {
          "type": "array",
          "items": {
            "enum": [
              "missing",
              "missing_plan",
              "missing_evidence",
              "stale",
              "status_folder_mismatch",
              "parse_error",
              "review_pending",
              "evidence_incomplete",
              "invalid_scheduling",
              "dependency_missing",
              "dependency_cycle",
              "duplicate_goal_key",
              "health_stale",
              "health_date_missing",
              "health_date_invalid",
              "health_date_future",
              "health_date_order",
              "health_completion_inconsistent",
              "health_evidence_incomplete"
            ]
          }
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_version", "status", "evaluated_on", "last_activity", "findings"],
      "properties": {
        "policy_version": {"type": ["integer", "null"]},
        "status": {"enum": ["disabled", "healthy", "issues"]},
        "evaluated_on": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "last_activity": {"type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "rule", "severity", "field", "date", "age_days", "threshold_days"],
            "properties": {
              "code": {
                "enum": [
                  "health_stale",
                  "health_date_missing",
                  "health_date_invalid",
                  "health_date_future",
                  "health_date_order",
                  "health_completion_inconsistent",
                  "health_evidence_incomplete"
                ]
              },
              "rule": {"type": "string", "minLength": 1},
              "severity": {"enum": ["info", "warning", "error"]},
              "field": {"type": "string", "minLength": 1},
              "date": {"type": ["string", "null"]},
              "age_days": {"type": ["integer", "null"], "minimum": 0},
              "threshold_days": {"type": ["integer", "null"], "minimum": 0}
            }
          }
        }
      }
    },
    "scheduling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority", "depends_on", "status", "queue_position", "unmet_dependencies"],
      "properties": {
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[^/]+/[^/]+$"
          }
        },
        "status": {
          "enum": ["not_ready", "runnable", "in_progress", "blocked", "dependency_blocked", "done", "invalid"]
        },
        "queue_position": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "unmet_dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[^/]+/[^/]+$"
          }
        }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next_goal", "next_planned_goal", "open_count", "runnable_count", "invalid_count"],
      "properties": {
        "next_goal": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "next_planned_goal": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "open_count": {
          "type": "integer",
          "minimum": 0
        },
        "runnable_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
