{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.goal-lifecycle/schemas/goal-registry.schema.json",
  "title": "Goal Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated", "roots"],
  "properties": {
    "version": {
      "const": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "health_policy": {
      "$ref": "#/$defs/health_policy"
    },
    "roots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "goal_root", "scope", "project", "active", "added", "last_seen"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "goal_root": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "enum": ["repo", "global", "harness"]
          },
          "project": {
            "type": "string",
            "minLength": 1
          },
          "active": {
            "type": "boolean"
          },
          "added": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "last_seen": {
            "type": ["string", "null"]
          }
        }
      }
    }
  },
  "$defs": {
    "health_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "enabled"],
      "properties": {
        "version": {
          "const": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "draft": {"type": "integer", "minimum": 0},
            "review_pending": {"type": "integer", "minimum": 0},
            "ready": {"type": "integer", "minimum": 0},
            "in_progress": {"type": "integer", "minimum": 0},
            "blocked": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
