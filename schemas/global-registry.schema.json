{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.goal-lifecycle/schemas/global-registry.schema.json",
  "title": "Global Goal Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated", "roots"],
  "properties": {
    "version": {
      "const": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "roots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "repo_root",
          "goal_root",
          "state_path",
          "scope",
          "project",
          "active",
          "added",
          "last_seen"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "repo_root": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:[A-Za-z]:[\\\\/]|\\\\\\\\)"
          },
          "goal_root": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:[A-Za-z]:[\\\\/]|\\\\\\\\)"
          },
          "state_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:[A-Za-z]:[\\\\/]|\\\\\\\\)"
          },
          "scope": {
            "enum": ["repo", "global", "harness"]
          },
          "project": {
            "type": "string",
            "minLength": 1
          },
          "active": {
            "type": "boolean"
          },
          "added": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "last_seen": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
